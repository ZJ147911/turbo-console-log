{
  "name": "quick-console",
  "displayName": "Quick Console",
  "version": "3.18.1",
  "description": "Automated logging for JavaScript, TypeScript, and PHP. Insert, manage, and clean log messages with AST-powered precision.",
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Snippets",
    "Visualization"
  ],
  "keywords": [
    "ast parser",
    "console log",
    "debug",
    "debugging",
    "developer tools",
    "error_log",
    "javascript",
    "laravel",
    "log management",
    "log panel",
    "multi-language",
    "nodejs",
    "php",
    "print_r",
    "productivity",
    "typescript",
    "var_dump",
    "vue",
    "wordpress"
  ],
  "bugs": {
    "url": "https://gitee.com/zj147/turbo-console-log/issues",
    "email": "zj147911@foxmail.com"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "git@gitee.com:zj147/turbo-console-log.git"
  },
  "publisher": "zj147",
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "rimraf out && mkdir out && esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild-base-minify": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "esbuild-base-minify-analyze": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify --analyze",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "watch": "npm run esbuild --watch",
    "fmt": "oxfmt",
    "prepare": "husky",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.94.0",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.40.0",
    "rimraf": "^6.1.3"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Quick Console 配置",
      "properties": {
        "quickConsole.wrapLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "确定是否自动换行日志消息。"
        },
        "quickConsole.logMessagePrefix": {
          "type": "string",
          "default": "🚀",
          "description": "日志消息的前缀。"
        },
        "quickConsole.logMessageSuffix": {
          "type": "string",
          "default": ":",
          "description": "日志消息的后缀。"
        },
        "quickConsole.includeFilename": {
          "type": "boolean",
          "default": true,
          "description": "是否在日志消息中包含文件名。"
        },
        "quickConsole.includeLineNum": {
          "type": "boolean",
          "default": true,
          "description": "是否在日志消息中包含行号。"
        },
        "quickConsole.addSemicolonInTheEnd": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息末尾添加分号。"
        },
        "quickConsole.insertEnclosingClass": {
          "type": "boolean",
          "default": true,
          "description": "是否在日志消息中包含选中变量所在的类名。"
        },
        "quickConsole.insertEnclosingFunction": {
          "type": "boolean",
          "default": true,
          "description": "是否在日志消息中包含选中变量所在的函数名。"
        },
        "quickConsole.insertEmptyLineBeforeLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息前插入空行。"
        },
        "quickConsole.insertEmptyLineAfterLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息后插入空行。"
        },
        "quickConsole.delimiterInsideMessage": {
          "type": "string",
          "default": "~",
          "description": "用于分隔日志消息中不同元素（文件名、行号、类、函数和变量）的分隔符。"
        },
        "quickConsole.quote": {
          "type": "string",
          "enum": [
            "\"",
            "'",
            "`"
          ],
          "default": "\"",
          "description": "引号类型：双引号、单引号或反引号。"
        },
        "quickConsole.logFunction": {
          "type": "string",
          "default": "log",
          "description": "指定使用 'displayCustomLogMessage' 命令时使用的日志函数。"
        },
        "quickConsole.consoleObject": {
          "type": "string",
          "default": "console",
          "description": "指定日志消息中使用的控制台对象名称。"
        }
      }
    },
    "commands": [
      {
        "command": "quickConsole.insertConsoleLog",
        "title": "Quick Console: 插入 console.log 日志消息"
      },
      {
        "command": "quickConsole.insertConsoleInfo",
        "title": "Quick Console: 插入 console.info 信息消息"
      },
      {
        "command": "quickConsole.insertConsoleDebug",
        "title": "Quick Console: 插入 console.debug 调试消息"
      },
      {
        "command": "quickConsole.insertConsoleTable",
        "title": "Quick Console: 插入 console.table 表格消息"
      },
      {
        "command": "quickConsole.insertConsoleWarn",
        "title": "Quick Console: 插入 console.warn 警告消息"
      },
      {
        "command": "quickConsole.insertConsoleError",
        "title": "Quick Console: 插入 console.error 错误消息"
      },
      {
        "command": "quickConsole.insertCustomLog",
        "title": "Quick Console: 插入自定义日志消息"
      },
      {
        "command": "quickConsole.commentAllLogMessages",
        "title": "Quick Console: 注释所有 Quick 日志消息"
      },
      {
        "command": "quickConsole.uncommentAllLogMessages",
        "title": "Quick Console: 取消注释所有 Quick 日志消息"
      },
      {
        "command": "quickConsole.deleteAllLogMessages",
        "title": "Quick Console: 删除所有 Quick 日志消息"
      },
      {
        "command": "quickConsole.correctAllLogMessages",
        "title": "Quick Console: 修正所有 Quick 日志消息"
      }
    ],
    "keybindings": [
      {
        "command": "quickConsole.insertConsoleLog",
        "key": "ctrl+k ctrl+l",
        "mac": "cmd+k cmd+l",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.insertConsoleInfo",
        "key": "ctrl+k ctrl+n",
        "mac": "cmd+k cmd+n",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.insertConsoleDebug",
        "key": "ctrl+k ctrl+b",
        "mac": "cmd+k cmd+b",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.insertConsoleTable",
        "key": "ctrl+k ctrl+t",
        "mac": "cmd+k cmd+t",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.insertConsoleWarn",
        "key": "ctrl+k ctrl+r",
        "mac": "cmd+k cmd+r",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.insertConsoleError",
        "key": "ctrl+k ctrl+e",
        "mac": "cmd+k cmd+e",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.insertCustomLog",
        "key": "ctrl+k ctrl+k",
        "mac": "cmd+k cmd+k",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.commentAllLogMessages",
        "key": "alt+shift+c",
        "mac": "alt+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.uncommentAllLogMessages",
        "key": "alt+shift+u",
        "mac": "alt+shift+u",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.deleteAllLogMessages",
        "key": "alt+shift+d",
        "mac": "alt+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "quickConsole.correctAllLogMessages",
        "key": "alt+shift+x",
        "mac": "alt+shift+x",
        "when": "editorTextFocus"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [],
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.94.0"
  }
}
