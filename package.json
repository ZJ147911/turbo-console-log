{
  "name": "quick-console",
  "displayName": "Quick Console",
  "version": "3.17.0",
  "description": "Automated logging for JavaScript, TypeScript, and PHP. Insert, manage, and clean log messages with AST-powered precision.",
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Snippets",
    "Visualization"
  ],
  "keywords": [
    "ast parser",
    "console log",
    "debug",
    "debugging",
    "developer tools",
    "error_log",
    "javascript",
    "laravel",
    "log management",
    "log panel",
    "multi-language",
    "nodejs",
    "php",
    "print_r",
    "productivity",
    "typescript",
    "var_dump",
    "vue",
    "wordpress"
  ],
  "bugs": {
    "url": "https://github.com/Chakroun-Anas/turbo-console-log/issues",
    "email": "chakroun.anas@outlook.com"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chakroun-Anas/turbo-console-log"
  },
  "publisher": "ChakrounAnas",
  "files": [
    "out/extension.js",
    "images/icon.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt",
    "package.json"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "rm -rf out && npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild-base-minify": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "esbuild-base-minify-analyze": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify --analyze",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "watch": "npm run esbuild --watch",
    "lint": "tsc --noEmit && eslint src --ext ts",
    "pretest": "yarn run esbuild-base",
    "test:compile": "rm -rf out && tsc -p ./ && mkdir out/mocha-tests/files && cp -r src/mocha-tests/files/ out/mocha-tests/files/",
    "test": "npm run test:compile && npm run test:jest && node ./out/mocha-tests/runTests.js",
    "test:jest": "jest --config jest.config.ts",
    "test:jest:coverage": "jest --config jest.config.ts --coverage",
    "test:jest:coverage:report": "jest --config jest.config.ts --coverage && open ./coverage/lcov-report/index.html",
    "fmt": "oxfmt"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/chai": "^5.0.0",
    "@types/glob": "^7.1.3",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^8.0.0",
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.94.0",
    "chai": "^4.3.7",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "glob": "^7.1.6",
    "jest": "^30.0.0",
    "mocha": "^11.2.2",
    "oxfmt": "^0.40.0",
    "ts-jest": "^29.4.0",
    "vscode-test": "^1.6.1"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Turbo Console Log 配置",
      "properties": {
        "turboConsoleLog.wrapLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "确定是否自动换行日志消息。"
        },
        "turboConsoleLog.logMessagePrefix": {
          "type": "string",
          "default": "🚀",
          "description": "日志消息的前缀。"
        },
        "turboConsoleLog.logMessageSuffix": {
          "type": "string",
          "default": ":",
          "description": "日志消息的后缀。"
        },
        "turboConsoleLog.includeFilename": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息中包含文件名。"
        },
        "turboConsoleLog.includeLineNum": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息中包含行号。"
        },
        "turboConsoleLog.addSemicolonInTheEnd": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息末尾添加分号。"
        },
        "turboConsoleLog.insertEnclosingClass": {
          "type": "boolean",
          "default": true,
          "description": "是否在日志消息中包含选中变量所在的类名。"
        },
        "turboConsoleLog.logCorrectionNotificationEnabled": {
          "type": "boolean",
          "default": false,
          "description": "是否启用日志修正通知。"
        },
        "turboConsoleLog.insertEnclosingFunction": {
          "type": "boolean",
          "default": true,
          "description": "是否在日志消息中包含选中变量所在的函数名。"
        },
        "turboConsoleLog.insertEmptyLineBeforeLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息前插入空行。"
        },
        "turboConsoleLog.insertEmptyLineAfterLogMessage": {
          "type": "boolean",
          "default": false,
          "description": "是否在日志消息后插入空行。"
        },
        "turboConsoleLog.delimiterInsideMessage": {
          "type": "string",
          "default": "~",
          "description": "用于分隔日志消息中不同元素（文件名、行号、类、函数和变量）的分隔符。"
        },
        "turboConsoleLog.quote": {
          "type": "string",
          "enum": [
            "\"",
            "'",
            "`"
          ],
          "default": "\"",
          "description": "引号类型：双引号、单引号或反引号。"
        },
        "turboConsoleLog.logFunction": {
          "type": "string",
          "default": "log",
          "description": "指定使用 'displayCustomLogMessage' 命令时使用的日志函数。"
        },
        "turboConsoleLog.isTurboTelemetryEnabled": {
          "type": "boolean",
          "default": true,
          "description": "启用匿名遥测以收集 Turbo Console Log 分析数据（遵循 VS Code 的全局遥测设置）。这有助于改进扩展，但绝不会收集个人信息。",
          "tags": [
            "telemetry",
            "usesOnlineServices"
          ]
        }
      }
    },
    "commands": [
      {
        "command": "turboConsoleLog.insertConsoleLog",
        "title": "Turbo Console Log: 插入 console.log 日志消息"
      },
      {
        "command": "turboConsoleLog.insertConsoleInfo",
        "title": "Turbo Console Log: 插入 console.info 信息消息"
      },
      {
        "command": "turboConsoleLog.insertConsoleDebug",
        "title": "Turbo Console Log: 插入 console.debug 调试消息"
      },
      {
        "command": "turboConsoleLog.insertConsoleTable",
        "title": "Turbo Console Log: 插入 console.table 表格消息"
      },
      {
        "command": "turboConsoleLog.insertConsoleWarn",
        "title": "Turbo Console Log: 插入 console.warn 警告消息"
      },
      {
        "command": "turboConsoleLog.insertConsoleError",
        "title": "Turbo Console Log: 插入 console.error 错误消息"
      },
      {
        "command": "turboConsoleLog.insertCustomLog",
        "title": "Turbo Console Log: 插入自定义日志消息"
      },
      {
        "command": "turboConsoleLog.commentAllLogMessages",
        "title": "Turbo Console Log: 注释所有 Turbo 日志消息"
      },
      {
        "command": "turboConsoleLog.uncommentAllLogMessages",
        "title": "Turbo Console Log: 取消注释所有 Turbo 日志消息"
      },
      {
        "command": "turboConsoleLog.deleteAllLogMessages",
        "title": "Turbo Console Log: 删除所有 Turbo 日志消息"
      },
      {
        "command": "turboConsoleLog.correctAllLogMessages",
        "title": "Turbo Console Log: 修正所有 Turbo 日志消息"
      }
    ],
    "keybindings": [
      {
        "command": "turboConsoleLog.insertConsoleLog",
        "key": "ctrl+k ctrl+l",
        "mac": "cmd+k cmd+l",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.insertConsoleInfo",
        "key": "ctrl+k ctrl+n",
        "mac": "cmd+k cmd+n",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.insertConsoleDebug",
        "key": "ctrl+k ctrl+b",
        "mac": "cmd+k cmd+b",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.insertConsoleTable",
        "key": "ctrl+k ctrl+t",
        "mac": "cmd+k cmd+t",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.insertConsoleWarn",
        "key": "ctrl+k ctrl+r",
        "mac": "cmd+k cmd+r",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.insertConsoleError",
        "key": "ctrl+k ctrl+e",
        "mac": "cmd+k cmd+e",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.insertCustomLog",
        "key": "ctrl+k ctrl+k",
        "mac": "cmd+k cmd+k",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.commentAllLogMessages",
        "key": "alt+shift+c",
        "mac": "alt+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.uncommentAllLogMessages",
        "key": "alt+shift+u",
        "mac": "alt+shift+u",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.deleteAllLogMessages",
        "key": "alt+shift+d",
        "mac": "alt+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "turboConsoleLog.correctAllLogMessages",
        "key": "alt+shift+x",
        "mac": "alt+shift+x",
        "when": "editorTextFocus"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [],

  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.94.0"
  },
  "__metadata": {
    "id": "6623619a-676d-4cde-943f-a3c193b44fc0",
